{
  "name": "napcat-plugin-ai-chat-template",
  "plugin": "AI 群聊模板",
  "version": "1.0.0",
  "type": "module",
  "main": "index.mjs",
  "description": "NapCat 通用 AI 群聊 / 私聊模板插件",
  "author": "sanxi",
  "license": "MIT",
  "keywords": [
    "napcat",
    "plugin",
    "qq",
    "template",
    "ai",
    "chat"
  ],
  "napcat": {
    "tags": [
      "工具",
      "AI"
    ],
    "minVersion": "4.14.0",
    "homepage": "https://github.com/sanxi33/napcat-plugin-ai-chat-template"
  },
  "dependencies": {
    "napcat-types": "0.0.16"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.33",
    "napcat-plugin-debug-cli": "^1.2.8",
    "playwright-core": "^1.59.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.1.4",
    "ws": "^8.19.0"
  },
  "scripts": {
    "build": "vite build",
    "build:webui": "cd src/webui && pnpm install && pnpm run build",
    "dev:webui": "cd src/webui && pnpm run dev",
    "watch": "vite build --watch",
    "dev": "vite build --watch",
    "push": "vite build",
    "deploy": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "screenshots": "node scripts/generate-screenshots.mjs"
  }
}
